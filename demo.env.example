# Copy this file to demo.env, fill in the values, then run scripts/render.sh.
# demo.env is gitignored — it will contain secrets.

# Hostname for the Keycloak route. Must be under your cluster's apps wildcard
# domain (*.apps.<cluster-domain>), so the default router certificate covers it.
KC_ROUTE_HOST=keycloak.apps.ocp.example.com

# Hostname of the OpenShift OAuth server route (oc get route oauth-openshift -n openshift-authentication).
OAUTH_HOST=oauth-openshift.apps.ocp.example.com

# Teleport proxy address (no port). This Teleport cluster must be Enterprise —
# the SAML identity provider is an Enterprise feature.
TELEPORT_PROXY=example.teleport.sh

# Shared secret between Keycloak's `openshift` OIDC client and OpenShift's OAuth
# server. Generate one: openssl rand -hex 24
OIDC_CLIENT_SECRET=

# Password for Keycloak's local `admin` account (admin console access).
# Generate one: openssl rand -hex 12
KC_ADMIN_PASSWORD=

# Teleport's SAML signing certificate as a single line of base64 (no newlines).
# tctl exports it in binary DER form with a trailing newline that Keycloak
# rejects ("extra data at the end"), so normalize it through openssl:
#   tctl auth export --type saml-idp | openssl x509 -inform DER | grep -v CERTIFICATE | tr -d '\n'
TELEPORT_SAML_CERT_B64=
