# Copy this file to demo.env and fill in the values, then run scripts/render.sh.
#
# This file contains NO secrets — only hostnames. The OIDC client secret is
# generated in-cluster by scripts/rotate-client-secret.sh (it never touches
# disk), and the Teleport SAML signing certificate (public key material) is
# synced by scripts/sync-saml-cert.sh.

# Hostname for the Keycloak route. Must be under your cluster's apps wildcard
# domain (*.apps.<cluster-domain>), so the default router certificate covers it.
KC_ROUTE_HOST=keycloak.apps.ocp.example.com

# Hostname of the OpenShift OAuth server route (oc get route oauth-openshift -n openshift-authentication).
OAUTH_HOST=oauth-openshift.apps.ocp.example.com

# Hostname of the OpenShift web console (oc get route console -n openshift-console).
# Used as the launch URL on the Teleport application tile.
CONSOLE_HOST=console-openshift-console.apps.ocp.example.com

# Teleport proxy address (no port). This Teleport cluster must be Enterprise —
# the SAML identity provider is an Enterprise feature.
TELEPORT_PROXY=example.teleport.sh
